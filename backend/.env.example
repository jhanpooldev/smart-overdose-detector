# ─── Base de datos ────────────────────────────────────────────────────────────
# Formatos válidos:
#   Local:      postgresql://usuario:password@localhost:5432/nombre_db
#   Supabase:   postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
#   Neon:       postgresql://[user]:[password]@[host]/[dbname]?sslmode=require
#   Docker:     postgresql://sod_user:sod_secret@localhost:5432/overdose_detector
DATABASE_URL=postgresql://sod_user:sod_secret@localhost:5432/overdose_detector

# ─── Entorno ──────────────────────────────────────────────────────────────────
# development | production
ENV=development

# ─── Backend de persistencia ──────────────────────────────────────────────────
# memory   → RAM (sin BD, para tests rápidos)
# postgres → PostgreSQL real
STORAGE_BACKEND=memory

# ─── Seguridad JWT ────────────────────────────────────────────────────────────
# Genera una clave segura con:
#   python -c "import secrets; print(secrets.token_hex(32))"
# NUNCA commits esta clave en el repositorio.
SECRET_KEY=CAMBIA_ESTO_CON_UNA_CLAVE_SEGURA_DE_64_CHARS

# Duración del token de acceso en minutos (por defecto 24h = 1440 min)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Lista de orígenes permitidos separados por coma (sin espacios)
# En producción usa el dominio real de tu app, NO "*"
ALLOWED_ORIGINS=http://localhost,http://localhost:8080,http://localhost:3000
